<!DOCTYPE html>
<html>

<head>
    <style>

        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .store-box {
            background-color: rgb(1, 1, 109);
            color: rgb(250, 94, 224);
            padding: 15px 20px;
            border-radius: 8px;
            margin: 16px 0;
            text-align: center;
        }

        .store-box h2 {
            margin: 0;
            font-size: 20px;
        }

        .store-box p {
            margin: 6px 0 0;
            font-size: 13px;
            opacity: 0.8;
        }

        .steps {
            margin: 16px 0;
            padding-left: 20px;
        }

        .steps li {
            margin-bottom: 8px;
            font-weight: bold;
        }

                body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }

        .header {
            background-color: rgb(1, 1, 109);
            color: #dec1ff;
            padding: 20px;
            text-align: center;
        }

        .content {
            padding: 20px;
            /* background-color: #dec1ff !important; */
            color: #dec1ff;
            
        }

        .footer {
            background-color: rgb(1, 1, 109);
            color: #dec1ff;
            padding: 10px;
            text-align: center;
            font-size: 12px;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="header">
            <h1>Hello, <%= firstName %>!</h1>
        </div>

        <div class="content">
            <p class="content">Welcome to Nana's Pourfection Hub!</p>
            <p>You have successfully logged out of your account.</p>
            <p>If you did not authorize this logout, please contact our support team immediately.</p>
            <p>Best regards,<br>The Nana's Pourfection Hub Team</p>
        </div>

         <div class="footer">
            <p>&copy; <%= new Date().getFullYear() %> Nana's Pourfection Hub. All rights reserved.</p>
        </div>
    </div>
</body>

</html>