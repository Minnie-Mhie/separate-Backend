<!DOCTYPE html>
<html>
<head>
    <style>
                body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }

        .header {
            background-color: rgb(1, 1, 109);
            color: #dec1ff;
            padding: 20px;
            text-align: center;
        }

        .content {
            padding: 20px;
            /* background-color: #dec1ff !important; */
            color: #dec1ff;
            
        }

        .footer {
            background-color: rgb(1, 1, 109);
            color: #dec1ff;
            padding: 10px;
            text-align: center;
            font-size: 12px;
        }
        .message-box { background-color: rgb(1, 1, 109); color: #dec1ff; padding: 15px 20px; border-radius: 8px; margin: 16px 0; }
        .message-box p { margin: 4px 0; font-size: 14px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>New Contact Message</h1>
            <p>Someone reached out via the Contact Us page</p>
        </div>
        <div class="content">
            <p>You have received a new message from a visitor on Nana's Pourfection Hub.</p>

            <div class="message-box">
                <p><strong>Name:</strong> <%= name %></p>
                <p><strong>Email:</strong> <%= email %></p>
                <p><strong>Message:</strong></p>
                <p><%= message %></p>
            </div>

            <p>You can reply directly to this person by emailing <strong><%= email %></strong>.</p>
            <p>Best regards,<br>Nana's Pourfection Hub System</p>
        </div>
        <div class="footer">
            <p>This email was sent by Nana's Pourfection Hub &copy; <%= new Date().getFullYear() %></p>
        </div>
    </div>
</body>
</html>